package LibraryManagementSystem;

// Customer is a pure data entity — same role as Vehicle in parking lot.
// It does NOT have borrow() or return() methods.
// WHY? Because the customer doesn't process themselves.
// LibraryController does that, using the customer as input.
//
// Analogy: a Vehicle doesn't call park() on itself.
// The EntrancePanel does it, receiving the Vehicle as a parameter.

public class Customer {

    String customerId;
    String customerName;

    public Customer(String customerId, String customerName) {
        this.customerId = customerId;
        this.customerName = customerName;
    }
}
